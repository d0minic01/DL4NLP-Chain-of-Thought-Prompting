{
  "elements": "[\n  {\"type\":\"cameraUpdate\",\"width\":600,\"height\":450,\"x\":200,\"y\":-20},\n  {\"type\":\"text\",\"id\":\"title\",\"x\":300,\"y\":5,\"text\":\"LLM Evaluation Design Framework\",\"fontSize\":28,\"strokeColor\":\"#1e1e1e\"},\n  {\"type\":\"text\",\"id\":\"subtitle\",\"x\":245,\"y\":42,\"text\":\"9 Prompting Techniques for Math Reasoning\",\"fontSize\":16,\"strokeColor\":\"#757575\"},\n\n  {\"type\":\"cameraUpdate\",\"width\":600,\"height\":450,\"x\":-50,\"y\":55},\n  {\"type\":\"text\",\"id\":\"mathead\",\"x\":210,\"y\":65,\"text\":\"The 2x2 Baseline Matrix (Techniques 1-4)\",\"fontSize\":20,\"strokeColor\":\"#1e1e1e\"},\n  {\"type\":\"rectangle\",\"id\":\"matbg\",\"x\":20,\"y\":85,\"width\":940,\"height\":295,\"backgroundColor\":\"#dbe4ff\",\"fillStyle\":\"solid\",\"strokeColor\":\"#4a9eed\",\"strokeWidth\":1,\"opacity\":25,\"roundness\":{\"type\":3},\"label\":{\"text\":\" \",\"fontSize\":16}},\n  {\"type\":\"text\",\"id\":\"ch1\",\"x\":215,\"y\":95,\"text\":\"No Instruction\",\"fontSize\":18,\"strokeColor\":\"#1e1e1e\"},\n  {\"type\":\"text\",\"id\":\"ch2\",\"x\":545,\"y\":95,\"text\":\"Think Step by Step\",\"fontSize\":18,\"strokeColor\":\"#1e1e1e\"},\n  {\"type\":\"text\",\"id\":\"rl1\",\"x\":45,\"y\":165,\"text\":\"0-Shot\",\"fontSize\":18,\"strokeColor\":\"#1e1e1e\"},\n  {\"type\":\"text\",\"id\":\"rl2\",\"x\":45,\"y\":290,\"text\":\"8-Shot\",\"fontSize\":18,\"strokeColor\":\"#1e1e1e\"},\n  {\"type\":\"rectangle\",\"id\":\"c1\",\"x\":140,\"y\":115,\"width\":280,\"height\":100,\"backgroundColor\":\"#fff3bf\",\"fillStyle\":\"solid\",\"roundness\":{\"type\":3},\"strokeColor\":\"#f59e0b\",\"label\":{\"text\":\"1. true_baseline\\n0-shot, no instruction\",\"fontSize\":16}},\n  {\"type\":\"rectangle\",\"id\":\"c2\",\"x\":480,\"y\":115,\"width\":280,\"height\":100,\"backgroundColor\":\"#fff3bf\",\"fillStyle\":\"solid\",\"roundness\":{\"type\":3},\"strokeColor\":\"#f59e0b\",\"label\":{\"text\":\"2. think_step_by_step\\n0-shot + instruction\",\"fontSize\":16}},\n  {\"type\":\"rectangle\",\"id\":\"c3\",\"x\":140,\"y\":240,\"width\":280,\"height\":100,\"backgroundColor\":\"#a5d8ff\",\"fillStyle\":\"solid\",\"roundness\":{\"type\":3},\"strokeColor\":\"#4a9eed\",\"label\":{\"text\":\"3. fewshot_baseline\\n8-shot, answer only\",\"fontSize\":16}},\n  {\"type\":\"rectangle\",\"id\":\"c4\",\"x\":480,\"y\":240,\"width\":280,\"height\":100,\"backgroundColor\":\"#a5d8ff\",\"fillStyle\":\"solid\",\"roundness\":{\"type\":3},\"strokeColor\":\"#4a9eed\",\"label\":{\"text\":\"4. fewshot_tss\\n8-shot + instruction\",\"fontSize\":16}},\n  {\"type\":\"arrow\",\"id\":\"ha1\",\"x\":420,\"y\":165,\"width\":60,\"height\":0,\"points\":[[0,0],[60,0]],\"strokeColor\":\"#8b5cf6\",\"strokeWidth\":2,\"endArrowhead\":\"arrow\",\"label\":{\"text\":\"CoT?\",\"fontSize\":14}},\n  {\"type\":\"arrow\",\"id\":\"ha2\",\"x\":420,\"y\":290,\"width\":60,\"height\":0,\"points\":[[0,0],[60,0]],\"strokeColor\":\"#8b5cf6\",\"strokeWidth\":2,\"endArrowhead\":\"arrow\",\"label\":{\"text\":\"CoT?\",\"fontSize\":14}},\n  {\"type\":\"arrow\",\"id\":\"va1\",\"x\":280,\"y\":215,\"width\":0,\"height\":25,\"points\":[[0,0],[0,25]],\"strokeColor\":\"#22c55e\",\"strokeWidth\":2,\"endArrowhead\":\"arrow\",\"label\":{\"text\":\"Shots?\",\"fontSize\":14}},\n  {\"type\":\"arrow\",\"id\":\"va2\",\"x\":620,\"y\":215,\"width\":0,\"height\":25,\"points\":[[0,0],[0,25]],\"strokeColor\":\"#22c55e\",\"strokeWidth\":2,\"endArrowhead\":\"arrow\",\"label\":{\"text\":\"Shots?\",\"fontSize\":14}},\n  {\"type\":\"text\",\"id\":\"icn1\",\"x\":420,\"y\":210,\"text\":\"Interaction\",\"fontSize\":14,\"strokeColor\":\"#757575\"},\n  {\"type\":\"text\",\"id\":\"legend1\",\"x\":110,\"y\":360,\"text\":\"Purple = CoT instruction effect    Green = few-shot effect    Center = interaction of both\",\"fontSize\":14,\"strokeColor\":\"#757575\"},\n  {\"type\":\"text\",\"id\":\"cmpq\",\"x\":110,\"y\":382,\"text\":\"Rows (1v3, 2v4): Do format examples help?   Cols (1v2, 3v4): Does Think step by step help?\",\"fontSize\":14,\"strokeColor\":\"#757575\"},\n\n  {\"type\":\"cameraUpdate\",\"width\":600,\"height\":450,\"x\":-30,\"y\":400},\n  {\"type\":\"text\",\"id\":\"coth\",\"x\":220,\"y\":408,\"text\":\"CoT Style Variations (Techniques 5-9, all 8-shot)\",\"fontSize\":20,\"strokeColor\":\"#1e1e1e\"},\n  {\"type\":\"rectangle\",\"id\":\"cotbg\",\"x\":20,\"y\":430,\"width\":1120,\"height\":170,\"backgroundColor\":\"#e5dbff\",\"fillStyle\":\"solid\",\"strokeColor\":\"#8b5cf6\",\"strokeWidth\":1,\"opacity\":25,\"roundness\":{\"type\":3},\"label\":{\"text\":\" \",\"fontSize\":16}},\n  {\"type\":\"text\",\"id\":\"cotintro\",\"x\":80,\"y\":435,\"text\":\"Same 8 questions as technique 3, but assistant responses contain reasoning traces in different styles:\",\"fontSize\":14,\"strokeColor\":\"#757575\"},\n  {\"type\":\"rectangle\",\"id\":\"cot5\",\"x\":40,\"y\":460,\"width\":210,\"height\":135,\"backgroundColor\":\"#d0bfff\",\"fillStyle\":\"solid\",\"roundness\":{\"type\":3},\"strokeColor\":\"#8b5cf6\",\"label\":{\"text\":\"5. Persona CoT\\n\\nAs a mathematician:\\ntotal is 21 - 15 = 6\",\"fontSize\":14}},\n  {\"type\":\"rectangle\",\"id\":\"cot6\",\"x\":270,\"y\":460,\"width\":210,\"height\":135,\"backgroundColor\":\"#d0bfff\",\"fillStyle\":\"solid\",\"roundness\":{\"type\":3},\"strokeColor\":\"#8b5cf6\",\"label\":{\"text\":\"6. Contrastive CoT\\n\\n[INCORRECT] 2 cars...\\n[CORRECT] 3 + 2 = 5 cars\",\"fontSize\":14}},\n  {\"type\":\"rectangle\",\"id\":\"cot7\",\"x\":500,\"y\":460,\"width\":210,\"height\":135,\"backgroundColor\":\"#d0bfff\",\"fillStyle\":\"solid\",\"roundness\":{\"type\":3},\"strokeColor\":\"#8b5cf6\",\"label\":{\"text\":\"7. Numbered Step\\n\\nStep 1: 3 cars\\nStep 2: 3 + 2 = 5\",\"fontSize\":14}},\n  {\"type\":\"rectangle\",\"id\":\"cot8\",\"x\":730,\"y\":460,\"width\":190,\"height\":135,\"backgroundColor\":\"#d0bfff\",\"fillStyle\":\"solid\",\"roundness\":{\"type\":3},\"strokeColor\":\"#8b5cf6\",\"label\":{\"text\":\"8. Equation Only\\n\\n3 + 2 = 5.\\nThe answer is 5.\",\"fontSize\":14}},\n  {\"type\":\"rectangle\",\"id\":\"cot9\",\"x\":940,\"y\":460,\"width\":190,\"height\":135,\"backgroundColor\":\"#d0bfff\",\"fillStyle\":\"solid\",\"roundness\":{\"type\":3},\"strokeColor\":\"#8b5cf6\",\"label\":{\"text\":\"9. Caveman Mode\\n\\n3 car in lot.\\n2 more car come.\\n3 + 2 = 5 car.\",\"fontSize\":14}},\n  {\"type\":\"text\",\"id\":\"cotq\",\"x\":120,\"y\":605,\"text\":\"Key question: Which reasoning style (5-9) beats answer-only few-shot (3-4)?  Which works best?\",\"fontSize\":14,\"strokeColor\":\"#757575\"},\n\n  {\"type\":\"cameraUpdate\",\"width\":600,\"height\":450,\"x\":-30,\"y\":620},\n  {\"type\":\"text\",\"id\":\"pah\",\"x\":50,\"y\":625,\"text\":\"Prompt Architecture (chat template always applied)\",\"fontSize\":20,\"strokeColor\":\"#1e1e1e\"},\n  {\"type\":\"rectangle\",\"id\":\"pabg\",\"x\":20,\"y\":645,\"width\":1120,\"height\":220,\"backgroundColor\":\"#dbe4ff\",\"fillStyle\":\"solid\",\"strokeColor\":\"#4a9eed\",\"strokeWidth\":1,\"opacity\":18,\"roundness\":{\"type\":3},\"label\":{\"text\":\" \",\"fontSize\":16}},\n  {\"type\":\"rectangle\",\"id\":\"sys\",\"x\":50,\"y\":658,\"width\":1060,\"height\":36,\"backgroundColor\":\"#ffd8a8\",\"fillStyle\":\"solid\",\"roundness\":{\"type\":3},\"strokeColor\":\"#f59e0b\",\"label\":{\"text\":\"<|im_start|>system  Always end your response with: The answer is <your answer>.  <|im_end|>\",\"fontSize\":14}},\n  {\"type\":\"arrow\",\"id\":\"pa1\",\"x\":520,\"y\":694,\"width\":0,\"height\":15,\"points\":[[0,0],[0,15]],\"strokeColor\":\"#1e1e1e\",\"strokeWidth\":2,\"endArrowhead\":\"arrow\"},\n  {\"type\":\"text\",\"id\":\"fsh\",\"x\":50,\"y\":712,\"text\":\"Few-shot examples (8x, used by techniques 3-9):\",\"fontSize\":14,\"strokeColor\":\"#757575\"},\n  {\"type\":\"rectangle\",\"id\":\"exu\",\"x\":50,\"y\":730,\"width\":510,\"height\":36,\"backgroundColor\":\"#a5d8ff\",\"fillStyle\":\"solid\",\"roundness\":{\"type\":3},\"strokeColor\":\"#4a9eed\",\"label\":{\"text\":\"<|im_start|>user  '15 trees... after done 21 trees...'|im_end|>\",\"fontSize\":14}},\n  {\"type\":\"arrow\",\"id\":\"paex\",\"x\":560,\"y\":748,\"width\":20,\"height\":0,\"points\":[[0,0],[20,0]],\"strokeColor\":\"#1e1e1e\",\"strokeWidth\":1,\"endArrowhead\":\"arrow\"},\n  {\"type\":\"rectangle\",\"id\":\"exa\",\"x\":600,\"y\":730,\"width\":510,\"height\":36,\"backgroundColor\":\"#b2f2bb\",\"fillStyle\":\"solid\",\"roundness\":{\"type\":3},\"strokeColor\":\"#22c55e\",\"label\":{\"text\":\"<|im_start|>assistant  (answer-only OR reasoning trace)  |im_end|>\",\"fontSize\":14}},\n  {\"type\":\"arrow\",\"id\":\"pa2\",\"x\":520,\"y\":766,\"width\":0,\"height\":15,\"points\":[[0,0],[0,15]],\"strokeColor\":\"#1e1e1e\",\"strokeWidth\":2,\"endArrowhead\":\"arrow\"},\n  {\"type\":\"rectangle\",\"id\":\"tq\",\"x\":50,\"y\":782,\"width\":1060,\"height\":40,\"backgroundColor\":\"#ffc9c9\",\"fillStyle\":\"solid\",\"roundness\":{\"type\":3},\"strokeColor\":\"#ef4444\",\"label\":{\"text\":\"<|im_start|>user  Test Q: 'apples $2, oranges $3...'  [+ 'Think step by step.' for tech 2,4]  <|im_end|>\",\"fontSize\":14}},\n  {\"type\":\"arrow\",\"id\":\"pa3\",\"x\":520,\"y\":822,\"width\":0,\"height\":13,\"points\":[[0,0],[0,13]],\"strokeColor\":\"#1e1e1e\",\"strokeWidth\":2,\"endArrowhead\":\"arrow\"},\n  {\"type\":\"rectangle\",\"id\":\"gen\",\"x\":50,\"y\":835,\"width\":1060,\"height\":28,\"backgroundColor\":\"#d0bfff\",\"fillStyle\":\"solid\",\"roundness\":{\"type\":3},\"strokeColor\":\"#8b5cf6\",\"label\":{\"text\":\"<|im_start|>assistant   < model generates here (greedy, temp=0) >\",\"fontSize\":14}},\n\n  {\"type\":\"cameraUpdate\",\"width\":600,\"height\":450,\"x\":-50,\"y\":870},\n  {\"type\":\"text\",\"id\":\"eph\",\"x\":50,\"y\":875,\"text\":\"Evaluation Pipeline\",\"fontSize\":20,\"strokeColor\":\"#1e1e1e\"},\n  {\"type\":\"rectangle\",\"id\":\"p1\",\"x\":50,\"y\":905,\"width\":150,\"height\":65,\"backgroundColor\":\"#ffd8a8\",\"fillStyle\":\"solid\",\"roundness\":{\"type\":3},\"strokeColor\":\"#f59e0b\",\"label\":{\"text\":\"System + User\\n(chat template)\",\"fontSize\":14}},\n  {\"type\":\"arrow\",\"id\":\"pb1\",\"x\":200,\"y\":937,\"width\":35,\"height\":0,\"points\":[[0,0],[35,0]],\"strokeColor\":\"#1e1e1e\",\"strokeWidth\":2,\"endArrowhead\":\"arrow\"},\n  {\"type\":\"rectangle\",\"id\":\"p2\",\"x\":235,\"y\":905,\"width\":140,\"height\":65,\"backgroundColor\":\"#d0bfff\",\"fillStyle\":\"solid\",\"roundness\":{\"type\":3},\"strokeColor\":\"#8b5cf6\",\"label\":{\"text\":\"Model\\n(greedy, temp=0)\",\"fontSize\":14}},\n  {\"type\":\"arrow\",\"id\":\"pb2\",\"x\":375,\"y\":937,\"width\":35,\"height\":0,\"points\":[[0,0],[35,0]],\"strokeColor\":\"#1e1e1e\",\"strokeWidth\":2,\"endArrowhead\":\"arrow\"},\n  {\"type\":\"rectangle\",\"id\":\"p3\",\"x\":410,\"y\":905,\"width\":140,\"height\":65,\"backgroundColor\":\"#a5d8ff\",\"fillStyle\":\"solid\",\"roundness\":{\"type\":3},\"strokeColor\":\"#4a9eed\",\"label\":{\"text\":\"Generated\\nResponse\",\"fontSize\":14}},\n  {\"type\":\"arrow\",\"id\":\"pb3\",\"x\":550,\"y\":937,\"width\":35,\"height\":0,\"points\":[[0,0],[35,0]],\"strokeColor\":\"#1e1e1e\",\"strokeWidth\":2,\"endArrowhead\":\"arrow\"},\n  {\"type\":\"rectangle\",\"id\":\"p4\",\"x\":585,\"y\":905,\"width\":160,\"height\":65,\"backgroundColor\":\"#fff3bf\",\"fillStyle\":\"solid\",\"roundness\":{\"type\":3},\"strokeColor\":\"#f59e0b\",\"label\":{\"text\":\"Regex Extract\\nstrict -> flexible\",\"fontSize\":14}},\n  {\"type\":\"arrow\",\"id\":\"pb4\",\"x\":745,\"y\":937,\"width\":35,\"height\":0,\"points\":[[0,0],[35,0]],\"strokeColor\":\"#1e1e1e\",\"strokeWidth\":2,\"endArrowhead\":\"arrow\"},\n  {\"type\":\"rectangle\",\"id\":\"p5\",\"x\":780,\"y\":905,\"width\":150,\"height\":65,\"backgroundColor\":\"#b2f2bb\",\"fillStyle\":\"solid\",\"roundness\":{\"type\":3},\"strokeColor\":\"#22c55e\",\"label\":{\"text\":\"Exact-match\\nAccuracy\",\"fontSize\":14}},\n  {\"type\":\"text\",\"id\":\"st\",\"x\":50,\"y\":980,\"text\":\"Engine: lm_eval (EleutherAI)  |  Stop: 'Question:', '</s>', '<|im_end|>'  |  Metric: exact-match after regex\",\"fontSize\":14,\"strokeColor\":\"#757575\"},\n\n  {\"type\":\"cameraUpdate\",\"width\":600,\"height\":450,\"x\":-50,\"y\":1010},\n  {\"type\":\"text\",\"id\":\"fairh\",\"x\":50,\"y\":1015,\"text\":\"Fairness Controls\",\"fontSize\":20,\"strokeColor\":\"#1e1e1e\"},\n  {\"type\":\"rectangle\",\"id\":\"fairbg\",\"x\":20,\"y\":1038,\"width\":1120,\"height\":135,\"backgroundColor\":\"#d3f9d8\",\"fillStyle\":\"solid\",\"strokeColor\":\"#22c55e\",\"strokeWidth\":1,\"opacity\":25,\"roundness\":{\"type\":3},\"label\":{\"text\":\" \",\"fontSize\":16}},\n  {\"type\":\"text\",\"id\":\"f1\",\"x\":50,\"y\":1048,\"text\":\"-  Same 8 questions, same order; only the assistant response text differs between techniques\",\"fontSize\":16,\"strokeColor\":\"#1e1e1e\"},\n  {\"type\":\"text\",\"id\":\"f2\",\"x\":50,\"y\":1075,\"text\":\"-  System instruction always present (format consistency across all runs)\",\"fontSize\":16,\"strokeColor\":\"#1e1e1e\"},\n  {\"type\":\"text\",\"id\":\"f3\",\"x\":50,\"y\":1102,\"text\":\"-  Chat template always applied (role structure consistent)\",\"fontSize\":16,\"strokeColor\":\"#1e1e1e\"},\n  {\"type\":\"text\",\"id\":\"f4\",\"x\":50,\"y\":1129,\"text\":\"-  Instruction-tuned models only; greedy decoding (temp=0, do_sample=False)\",\"fontSize\":16,\"strokeColor\":\"#1e1e1e\"},\n  {\"type\":\"text\",\"id\":\"f5\",\"x\":50,\"y\":1156,\"text\":\"-  Base (non-instruct) models excluded: their comparison would not be meaningful\",\"fontSize\":16,\"strokeColor\":\"#1e1e1e\"},\n\n  {\"type\":\"cameraUpdate\",\"width\":1600,\"height\":1200,\"x\":-100,\"y\":-30}\n]"
}